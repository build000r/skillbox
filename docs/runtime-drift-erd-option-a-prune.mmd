erDiagram
  RUNTIME_SKILLSET ||--|| SKILL_REPOS_CONFIG : uses
  SKILL_REPOS_CONFIG ||--o{ DECLARED_SKILL : declares
  SKILL_REPOS_CONFIG ||--|| REGENERATED_LOCKFILE : hashes_to
  REGENERATED_LOCKFILE ||--o{ LOCKED_DECLARED_SKILL : records
  RUNTIME_SKILLSET ||--o{ INSTALL_TARGET : installs_into
  INSTALL_TARGET ||--o{ INSTALLED_DECLARED_SKILL : contains
  INSTALL_TARGET ||--o{ REMOVED_EXTRA_SKILL : prunes
  LEGEND ||--o{ REMOVED_EXTRA_SKILL : red_means_removed

  RUNTIME_SKILLSET {
    string id "UNCHANGED default-skills"
    string profile "UNCHANGED core"
    string scope "UNCHANGED shared default pack"
  }
  SKILL_REPOS_CONFIG {
    string path "UNCHANGED workspace/skill-repos.yaml"
    string declared_count "UNCHANGED 17 skills"
  }
  DECLARED_SKILL {
    string examples "UNCHANGED ask-cascade, commit, skillbox-operator"
  }
  REGENERATED_LOCKFILE {
    string path "CHANGED workspace/skill-repos.lock.json"
    string config_sha "CHANGED matches config"
  }
  LOCKED_DECLARED_SKILL {
    string entries "CHANGED only declared skills"
  }
  INSTALL_TARGET {
    string claude "UNCHANGED home/.claude/skills"
    string codex "UNCHANGED home/.codex/skills"
  }
  INSTALLED_DECLARED_SKILL {
    string state "CHANGED only declared skills remain"
  }
  REMOVED_EXTRA_SKILL {
    string list "REMOVED cass, cass-memory, changelog-md, ga4, readme-writing, smart"
  }
  LEGEND {
    string green "ADDED"
    string amber "CHANGED"
    string red "REMOVED"
    string grey "UNCHANGED"
  }

  classDef unchanged fill:#f8fafc,stroke:#64748b,color:#0f172a
  classDef added fill:#dcfce7,stroke:#16a34a,color:#14532d,stroke-width:2px
  classDef changed fill:#fef3c7,stroke:#d97706,color:#78350f,stroke-width:2px
  classDef removed fill:#fee2e2,stroke:#dc2626,color:#7f1d1d,stroke-width:2px
  classDef decision fill:#ede9fe,stroke:#7c3aed,color:#3b0764,stroke-width:2px
  class RUNTIME_SKILLSET unchanged
  class SKILL_REPOS_CONFIG unchanged
  class DECLARED_SKILL unchanged
  class INSTALL_TARGET unchanged
  class REGENERATED_LOCKFILE changed
  class LOCKED_DECLARED_SKILL changed
  class INSTALLED_DECLARED_SKILL changed
  class REMOVED_EXTRA_SKILL removed
  class LEGEND decision
