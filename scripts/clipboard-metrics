#!/usr/bin/env python3
"""Summarize local smart-paste receipts without contacting a host."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
INSTALLED_LIB = Path.home() / ".local" / "share" / "skillbox" / "python"
for candidate in (INSTALLED_LIB, SCRIPT_DIR):
    try:
        sys.path.remove(str(candidate))
    except ValueError:
        pass
    sys.path.insert(0, str(candidate))

from lib import clipboard_metrics


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("paths", nargs="*", type=Path)
    args = parser.parse_args()
    paths = args.paths
    if not paths:
        root = Path.home() / ".cache" / "skillbox" / "smart-paste" / "receipts"
        paths = sorted(root.glob("*.json")) if root.is_dir() else []
    try:
        report = clipboard_metrics.summarize(clipboard_metrics.load_receipts(paths))
    except clipboard_metrics.MetricsError as exc:
        print(f"clipboard-metrics: {exc}", file=sys.stderr)
        return 1
    print(json.dumps(report, sort_keys=True, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
