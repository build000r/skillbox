#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
usage: clipimg-put [target|d|s|c|j] [remote-dir]

Copies the current macOS clipboard image to a reachable Skillbox host and puts the
remote image path back on the local clipboard.

Targets are resolved by the tracked Skillbox clipboard host registry. Common
aliases are d, s, c, and j; an explicit user@host uses the generic profile.

Default remote dir: ~/clipboard-images

Conference: direct WSL is preferred. Use the explicit conference1-ssh alias only
as the OSC52-hostile recovery path.
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    usage
    exit 0
fi

if [ "$(uname -s)" != "Darwin" ]; then
    echo "clipimg-put: this helper reads the macOS clipboard and must run locally on the Mac" >&2
    exit 1
fi

target_arg="${1:-d}"
remote_dir="${2:-~/clipboard-images}"
wsl_distro="${SKILLBOX_WSL_DISTRO:-Ubuntu}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd -P)"
if command -v clipboard-route >/dev/null 2>&1; then
    route_bin="$(command -v clipboard-route)"
elif [ -x "$script_dir/../clipboard-route" ]; then
    route_bin="$script_dir/../clipboard-route"
else
    echo "clipimg-put: clipboard-route is required; rerun scripts/clipboard-bootstrap --profile local" >&2
    exit 1
fi

route_args=("$route_bin" "$target_arg" --format tsv)
if [ -f "$script_dir/hosts.json" ]; then
    route_args+=(--hosts "$script_dir/hosts.json")
fi
if ! route_tsv="$("${route_args[@]}")"; then
    echo "clipimg-put: target is not present in the canonical clipboard route registry" >&2
    exit 1
fi
IFS=$'\t' read -r target transport remote_home _profile <<<"$route_tsv"
[ "$remote_home" = "-" ] && remote_home=""
[ "$transport" = "-" ] && transport="ssh"

if [ -z "$remote_home" ] && [ "$transport" != "wsl" ]; then
    remote_home="$(ssh -o BatchMode=yes -o ConnectTimeout=10 "$target" 'printf %s "$HOME"')"
fi

case "$remote_dir" in
    "~")
        remote_dir="$remote_home"
        ;;
    "~/"*)
        remote_dir="$remote_home/${remote_dir#\~/}"
        ;;
esac

workdir="$(mktemp -d "${TMPDIR:-/tmp}/clipimg-put.XXXXXX")"
trap 'rm -rf "$workdir"' EXIT
if command -v clipboard-snapshot >/dev/null 2>&1; then
    snapshot_bin="$(command -v clipboard-snapshot)"
elif [ -x "$script_dir/../clipboard-snapshot" ]; then
    snapshot_bin="$script_dir/../clipboard-snapshot"
else
    echo "clipimg-put: clipboard-snapshot is required; rerun scripts/clipboard-bootstrap --profile local" >&2
    exit 1
fi

if ! snapshot_json="$($snapshot_bin --materialize-dir "$workdir")"; then
    printf '%s\n' "$snapshot_json" >&2
    echo "clipimg-put: clipboard does not currently contain a supported image" >&2
    exit 1
fi
local_image="$(printf '%s' "$snapshot_json" | python3 -c 'import json,sys; p=json.load(sys.stdin); print(p.get("artifact") or "")')"
kind="$(printf '%s' "$snapshot_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("kind", ""))')"
if [ "$kind" != "image" ] || [ ! -f "$local_image" ]; then
    echo "clipimg-put: clipboard snapshot is '$kind', not an image" >&2
    exit 1
fi

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
extension=".${local_image##*.}"
remote_file="${remote_dir%/}/clipboard-${timestamp}${extension}"
printf -v remote_dir_q '%q' "$remote_dir"
printf -v remote_file_q '%q' "$remote_file"

if [ "$transport" = "wsl" ]; then
    encoded="$(base64 <"$local_image" | tr -d '\r\n')"
    ssh -o BatchMode=yes -o ConnectTimeout=10 "$target" "wsl -d $wsl_distro --cd ~ --exec bash -s" <<REMOTE
set -euo pipefail
mkdir -p $remote_dir_q
base64 -d > $remote_file_q <<'B64'
$encoded
B64
REMOTE
else
    ssh -o BatchMode=yes -o ConnectTimeout=10 "$target" "mkdir -p $remote_dir_q"
    scp -q "$local_image" "$target:$remote_file"
fi

printf '%s' "$remote_file" | /usr/bin/pbcopy
printf '%s\n' "$remote_file"
