#!/usr/bin/env bash
set -euo pipefail

native_macos_clipboard() {
    [ "$(uname -s)" = "Darwin" ] && [ -x /usr/bin/pbpaste ]
}

local_macos_session() {
    [ -z "${SSH_CONNECTION:-}" ] && [ -z "${SSH_CLIENT:-}" ] && [ -z "${SSH_TTY:-}" ]
}

if native_macos_clipboard && local_macos_session; then
    exec /usr/bin/pbpaste
fi

if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
    exec tmux save-buffer -
fi

if native_macos_clipboard; then
    exec /usr/bin/pbpaste
fi

echo "clippaste: remote reads from the Mac clipboard are terminal-owned; use Cmd+V or a tmux buffer" >&2
exit 1