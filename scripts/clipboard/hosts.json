{
  "bundle_version": 2,
  "source_dir": "scripts/clipboard",
  "profiles": {
    "local": {
      "label": "Operator Mac local install",
      "scope": "local",
      "transport": "local",
      "broker_strategy": "local",
      "display_strategy": "native",
      "trust": "local",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": true, "native_image_paste": true}
      }
    },
    "d3": {
      "label": "d3 portfolio devbox",
      "ssh_target": "skillbox@skillbox-portfolio-devbox",
      "remote_home": "/home/skillbox",
      "transport": "ssh",
      "broker_strategy": "negotiated",
      "display_strategy": "xvfb",
      "requires_ssh_tunnel": true,
      "trust": "allowlisted",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": true, "native_image_paste": true}
      }
    },
    "devbox": {
      "label": "Named devbox reached through d2",
      "scope": "nested",
      "parent_profile": "d3",
      "dynamic_target": true,
      "remote_home": "/home/skillbox",
      "transport": "ssh",
      "broker_strategy": "negotiated",
      "display_strategy": "xvfb",
      "requires_ssh_tunnel": true,
      "trust": "explicit",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": true, "native_image_paste": true}
      }
    },
    "sweet": {
      "label": "Sweet Potato",
      "ssh_target": "aiops@sweet-potato-prod",
      "remote_home": "/home/aiops",
      "transport": "ssh",
      "broker_strategy": "negotiated",
      "display_strategy": "xvfb",
      "requires_ssh_tunnel": true,
      "trust": "allowlisted",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": true, "native_image_paste": true}
      }
    },
    "jeremy": {
      "label": "Jeremy VPS",
      "ssh_target": "skillbox@skillbox-jeremy-3",
      "remote_home": "/home/skillbox",
      "transport": "ssh",
      "broker_strategy": "negotiated",
      "display_strategy": "xvfb",
      "requires_ssh_tunnel": true,
      "trust": "allowlisted",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": true, "native_image_paste": true}
      }
    },
    "conference1": {
      "label": "Conference1 direct WSL",
      "ssh_target": "worker@conference1-wsl",
      "remote_home": "/home/worker",
      "transport": "ssh",
      "preferred": true,
      "broker_strategy": "negotiated",
      "display_strategy": "xvfb",
      "requires_ssh_tunnel": true,
      "trust": "allowlisted",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": true, "native_image_paste": true}
      }
    },
    "conference1-fallback": {
      "label": "Conference1 Windows SSH wrapper",
      "ssh_target": "conference1-ssh",
      "remote_home": "/home/worker",
      "transport": "wsl",
      "fallback_only": true,
      "osc52_hostile": true,
      "broker_strategy": "none",
      "display_strategy": "none",
      "trust": "unsupported",
      "unsupported_reason": "Windows wrapper is OSC52-hostile and cannot own an exact WSL pane route",
      "capabilities": {
        "outbound": {"osc52_copy": false},
        "inbound": {"smart_path_paste": false, "native_image_paste": false}
      }
    },
    "generic": {
      "label": "Generic user@host",
      "scope": "remote",
      "dynamic_target": true,
      "transport": "ssh",
      "broker_strategy": "negotiated",
      "display_strategy": "none",
      "requires_ssh_tunnel": false,
      "trust": "explicit",
      "capabilities": {
        "outbound": {"osc52_copy": true},
        "inbound": {"smart_path_paste": false, "native_image_paste": false}
      }
    }
  },
  "aliases": {
    "d": "d3",
    "default": "d3",
    "portfolio": "d3",
    "skillbox-portfolio-devbox": "d3",
    "s": "sweet",
    "sp": "sweet",
    "sweet-potato": "sweet",
    "sweet-potato-prod": "sweet",
    "j": "jeremy",
    "jeremy-vps": "jeremy",
    "skillbox-jeremy": "jeremy",
    "skillbox-jeremy-3": "jeremy",
    "c": "conference1",
    "conf": "conference1",
    "conference": "conference1",
    "conference1-wsl": "conference1",
    "conference1-ssh": "conference1-fallback"
  },
  "conference1_tailnet": {
    "host": "conference1",
    "role": "heavy-build and dev-surface target",
    "os": "windows-with-wsl-ubuntu",
    "magicdns": "conference1.tail4c481e.ts.net",
    "tailscale_ip": "100.123.217.11",
    "windows_ssh_target": "conference1-ssh",
    "wsl_ssh_target": "worker@conference1-wsl",
    "wsl_tailscale_ip": "100.96.206.87",
    "serve_helper": "C:\\Users\\worker\\bin\\tailnet-serve.ps1",
    "serve_helper_actions": ["list", "expose", "remove"],
    "serve_backend_host": "127.0.0.1",
    "serve_ports": [3000, 3001, 3170, 3210, 8050],
    "portproxy_fallback": {
      "listen_address": "100.123.217.11",
      "list_command": "netsh interface portproxy show v4tov4",
      "note": "Raw Tailscale-IP portproxy; fallback only when MagicDNS Serve is unavailable."
    },
    "swimmers_remote_rust": {
      "host_env": "SWIMMERS_REMOTE_RUST_HOST",
      "host_values": ["conference1-ssh", "worker@100.123.217.11"],
      "build_side": "wsl-ubuntu",
      "wsl_ssh_target": "worker@conference1-wsl",
      "cargo_cache": "/var/tmp/swimmers-remote-rust-cache"
    },
    "security": {
      "posture": "tailnet-only",
      "rules": [
        "Reach services through Tailscale Serve / MagicDNS URLs on the tailnet.",
        "No 0.0.0.0 public binds; apps bind 127.0.0.1 and Serve proxies to them.",
        "No Tailscale Funnel unless the operator explicitly requests it."
      ]
    }
  },
  "conference_routing": {
    "direct_alias": "conference1-wsl",
    "direct_target": "worker@conference1-wsl",
    "fallback_alias": "conference1-ssh",
    "fallback_target": "conference1-ssh",
    "probe_reachability": "ssh -o BatchMode=yes -o ConnectTimeout=5 conference1-wsl true",
    "probe_mosh": "ssh -o BatchMode=yes -o ConnectTimeout=5 conference1-wsl 'command -v mosh-server'",
    "route_order": ["direct_wsl", "mosh_if_available", "fallback_ssh_wrapper"]
  }
}
