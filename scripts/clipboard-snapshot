#!/usr/bin/env python3
"""Capture one typed clipboard snapshot after an explicit paste gesture."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(Path.home() / ".local" / "share" / "skillbox" / "python"))
sys.path.insert(0, str(SCRIPT_DIR))

from lib import clipboard_snapshot as cs  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--fixture", type=Path, help="read a test payload instead of the live operator clipboard")
    parser.add_argument("--materialize-dir", type=Path, help="write image bytes to a private temporary artifact")
    parser.add_argument("--max-bytes", type=int, default=cs.DEFAULT_MAX_BYTES)
    args = parser.parse_args()
    try:
        payload = (
            json.loads(args.fixture.read_text(encoding="utf-8"))
            if args.fixture
            else cs.capture_operator_payload()
        )
        snapshot = cs.snapshot_from_payload(
            payload,
            output_dir=args.materialize_dir,
            max_bytes=args.max_bytes,
        )
    except cs.SnapshotError as exc:
        snapshot = cs.error_snapshot(exc)
    print(json.dumps(snapshot.public_dict(), sort_keys=True, separators=(",", ":")))
    return 0 if snapshot.ok else 2


if __name__ == "__main__":
    raise SystemExit(main())
