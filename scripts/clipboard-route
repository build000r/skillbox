#!/usr/bin/env python3
"""Resolve one Skillbox clipboard route through the canonical tracked registry."""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(Path.home() / ".local" / "share" / "skillbox" / "python"))
sys.path.insert(0, str(SCRIPT_DIR))

from lib import clipboard_route as cr  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("profile_or_alias")
    parser.add_argument("--target")
    parser.add_argument("--hosts", type=Path)
    parser.add_argument("--format", choices=("json", "tsv"), default="json")
    parser.add_argument("--validate", action="store_true")
    args = parser.parse_args()
    source_hosts = SCRIPT_DIR / "clipboard" / "hosts.json"
    default_hosts = source_hosts if source_hosts.is_file() else Path.home() / ".config" / "skillbox" / "clipboard-hosts.json"
    hosts = args.hosts or Path(os.environ.get("SKILLBOX_CLIPBOARD_HOSTS", default_hosts))
    try:
        data = cr.load_host_config(hosts)
        route = cr.resolve_profile(args.profile_or_alias, data=data, target=args.target)
    except (OSError, cr.HostConfigError, json.JSONDecodeError) as exc:
        print(json.dumps({"ok": False, "error": {"code": "route_invalid", "message": str(exc)}}))
        return 2
    if args.format == "tsv":
        values = (
            route.get("ssh_target") or "-",
            route.get("transport") or "-",
            route.get("remote_home") or "-",
            route["profile"],
        )
        print("\t".join(str(value) for value in values))
    else:
        print(json.dumps({"ok": True, "route": route}, sort_keys=True, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
