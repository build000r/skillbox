}

print_robot_docs() {
  cat <<EOF
Skillbox wrapper agent guide

Primary entrypoint:
  ${wrapper_name} <command> [options]

Start here:
  ${wrapper_name} capabilities --json
  ${wrapper_name} status --json
  ${wrapper_name} skills --issues-only --json
  ${wrapper_name} candidates --json
  ${wrapper_name} mcp --json
  ${wrapper_name} --robot-triage

Structured output:
  Use --json, or typo aliases --jason, --jsno, --jsson. Alias diagnostics go to stderr.
  Wrapper JSON mode forwards --format json to manage.py where supported.

Safe mutation pattern:
  ${wrapper_name} up <profile> <service> --dry-run --json
  ${wrapper_name} down <profile> <service> --dry-run --json
  ${wrapper_name} restart <profile> <service> --dry-run --json
  ${wrapper_name} launch <dir> <dir> --request "..." --dry-run --json
  ${wrapper_name} recalibrate --auto-fix
  ${wrapper_name} skill default on <skill> --repo --dry-run --format json

Skill verb contract:
  Machine map: ${wrapper_name} capabilities --json | jq .skill_verbs
  Read-only: recalibrate, plan, lint, why
  Session handoff: activate (mutates=cwd-ephemeral, returns_packet=true)
  Durable repo pins: on, off, heal (survive recalibrate)
  Durable defaults: default on/off <skill> --repo|--global (diff first; --global needs --yes)
  Link-only maintenance: add, move, remove, prune, sync
  Missing-skill fold: ${wrapper_name} recalibrate --auto-fix previews heal; add --yes to apply

Batch launcher:
  ${wrapper_name} launch <dir> <dir> --request 'Audit auth drift' --dry-run --json
  ${wrapper_name} bulk <dir> <dir> --request 'Audit auth drift' --dry-run --json
  bulk is an alias for launch. Use single quotes when prompts contain \$smart or other \$skill tokens.
EOF
}

print_robot_triage() {
  python3 - "${wrapper_name}" <<'PY'
from __future__ import annotations

import json
import sys

wrapper = sys.argv[1]
payload = {
    "ok": True,
    "tool": f"skillbox-{wrapper}",
    "quick_ref": [
        f"{wrapper} status --json",
        f"{wrapper} skills --issues-only --json",
        f"{wrapper} candidates --json",
        f"{wrapper} mcp --json",
        f"{wrapper} launch <dir> <dir> --request '<prompt>' --dry-run --json",
        f"{wrapper} up <profile> <service> --dry-run --json",
    ],
    "recommendations": [
        {"id": "runtime-status", "command": f"{wrapper} status --json", "why": "Fastest runtime state read."},
        {"id": "skill-drift", "command": f"{wrapper} skills --issues-only --json", "why": "Compact cwd skill-policy view."},
        {"id": "skill-candidates", "command": f"{wrapper} candidates --json", "why": "Explore linkable source skills before declaring the cwd surface complete."},
        {"id": "mcp-parity", "command": f"{wrapper} mcp --json", "why": "Checks Claude/Codex MCP visibility."},
        {"id": "preview-launch", "command": f"{wrapper} launch <dir> <dir> --request '<prompt>' --dry-run --json", "why": "Preview Swimmers batch-launch payloads before spawning agents."},
        {"id": "preview-services", "command": f"{wrapper} up <profile> <service> --dry-run --json", "why": "Preview service actions before mutation."},
    ],
}
print(json.dumps(payload, indent=2, sort_keys=True))
PY
}

skillbox_root="$(find_skillbox_root || true)"
if [[ -z "${skillbox_root}" ]]; then
  echo "${wrapper_name}: missing skillbox repo; set SKILLBOX_ROOT or install from a checkout" >&2
  exit 1
fi
configure_operator_defaults

case "${1:-}" in
  "" )
    ;;
  -h|--help|help)
    action="help"
    shift
    ;;
  capabilities|cap|caps)
    action="capabilities"
    shift
    ;;
  robot-docs|docs|guide|--robot-help)
    action="robot-docs"
    shift
    ;;
  robot-triage|triage|--robot-triage)
    action="robot-triage"
    shift
    ;;
  --json|--jason|--jsno|--jsson)
    action="status"
    ;;
  m|marketing)
    action="overlay-toggle"
    overlay_name="marketing"
    shift
    ;;
  overlay)
    action="overlay"
    shift
    ;;
  up|all)
    action="up"
    shift
    ;;
  down)
    action="down"
    shift
    ;;
  re|restart)
    action="restart"
    shift
    ;;
  status)
    action="status"
    shift
    ;;
  logs)
    action="logs"
    shift
    ;;
  launch|bulk|bulk-launch|swimmers-launch)
    action="swimmers-launch"
    shift
    ;;
  recalibrate|calibrate|rc)
    action="recalibrate"
    shift
    ;;
  candidates|candidate|explore|inventory)
    action="skill-candidates"
    shift
    ;;
  mcp|mcps)
    shift
    if [[ "${1:-}" == "sync" ]]; then
      action="mcp-sync"
      shift
    else
      action="mcp-audit"
    fi
    ;;
  fleet)
    action="fleet"
    shift
    ;;
  doctor|structure-doctor)
    action="structure-doctor"
    shift
    ;;
  registry|repos|repo-registry)
    action="repo-registry"
    shift
    ;;
  cass)
    action="cass"
    shift
    ;;
  evidence)
    action="cass-evidence"
    shift
    ;;
  cron)
    action="cron"
    shift
    ;;
  send-later|later|ntm-send-later)
    action="send-later"
    shift
    ;;
  beads|br)
    action="beads"
    shift
    ;;
  mmdx|mmd)
    action="mmdx"
    shift
    ;;
  hire|operator-booking)
    action="operator-booking"
    shift
    ;;
  sync)
    action="sync"
    shift
    ;;
  skill)
    action="skill"
    shift
    ;;
  skills)
    action="skills"
    shift
    ;;
  -*)
    ;;
  *)
    if [[ -n "${1:-}" ]]; then
      case "${1}" in
        statu|stats|state)
          suggestion="status"
          ;;
        log|logz)
          suggestion="logs"
          ;;
        skillz)
          suggestion="skills"
          ;;
        mc)
          suggestion="mcp"
          ;;
        *)
          suggestion="status"
          ;;
      esac
      echo "${wrapper_name}: unknown command '${1}'." >&2
      echo "Did you mean: ${wrapper_name} ${suggestion} --json" >&2
      echo "Discover commands: ${wrapper_name} capabilities --json" >&2
      exit 2
    fi
    ;;
esac

if [[ "${action}" != "mmdx" && "${action}" != "swimmers-launch" ]]; then
  case "${1:-}" in
    all|local-all)
      profile="local-all"
      shift
      ;;
    core|local-core)
      profile="local-core"
      shift
      ;;
    minimal|mini|local-minimal)
      profile="local-minimal"
      shift
      ;;
    backend|local-backend)
      profile="local-backend"
      shift
      ;;
    frontend|front|local-frontend)
      profile="local-frontend"
      shift
      ;;
    openclaw|claw|local-openclaw)
      profile="local-openclaw"
      shift
      ;;
  esac
fi

append_passthrough_token() {
  local token="$1"
  case "${action}" in
    sync)
      case "${token}" in
        --dry-run)
          sync_dry_run="true"
          ;;
        --yes)
          sync_yes="true"
          ;;
        *)
          sync_paths+=("${token}")
          ;;
      esac
      ;;
    skills|skill|skill-candidates|overlay|overlay-toggle|recalibrate|mcp-audit|mcp-sync|structure-doctor|repo-registry|cass|cass-evidence|cron|send-later|beads|mmdx|operator-booking|swimmers-launch|fleet)
      passthrough_args+=("${token}")
      ;;
    *)
      services+=("${token}")
      ;;
  esac
}

append_json_flag() {
  local token="$1"
  if [[ "${token}" != "--json" ]]; then
    json_alias_diagnostics+=("Interpreting ${token} as --format json. Exact command: ${wrapper_name} <command> --json")
  fi
  case "${action}" in
    up|down|restart|status|logs)
      runtime_args+=(--format json)
      ;;
    capabilities|robot-triage)
      ;;
    repo-registry|cass|cron)
      passthrough_args+=(--json)
      ;;
    *)
      passthrough_args+=(--format json)
      ;;
  esac
}

append_runtime_or_passthrough_flag() {
  local token="$1"
  case "${action}" in
    up|down|restart|status|logs)
      runtime_args+=("${token}")
      ;;
    *)
      append_passthrough_token "${token}"
      ;;
  esac
}

append_input_token() {
  local token="$1"
  case "${token}" in
    --json|--jason|--jsno|--jsson)
      append_json_flag "${token}"
      ;;
    --dry-run|--force|--yes|--full|--issues-only|--no-global|--no-project|--show-sources|--show-shadowed|--no-open|--tmux|--tmux-submit)
      append_runtime_or_passthrough_flag "${token}"
      ;;
    *)
      append_passthrough_token "${token}"
      ;;
  esac
}

passthrough_has_arg() {
  local wanted="$1"
  local token=""
  for token in "${passthrough_args[@]}"; do
    if [[ "${token}" == "${wanted}" ]]; then
      return 0
    fi
  done
  return 1
}

overlay_should_sync_policy() {
  local overlay_action="${passthrough_args[0]:-list}"
  case "${overlay_action}" in
    on|off|toggle|activate)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

while [[ $# -gt 0 ]]; do
  case "${1}" in
    --format)
      if [[ "${2:-}" == "json" ]]; then
        append_json_flag "--json"
        shift 2
        continue
      fi
      append_input_token "$1"
      ;;
    --wait-seconds|--mode|--lines|--limit)
      if [[ $# -lt 2 ]]; then
        echo "${wrapper_name}: ${1} requires a value" >&2
        exit 2
      fi
      case "${action}" in
        up|down|restart|status|logs)
          runtime_args+=("$1" "$2")
          ;;
        *)
          passthrough_args+=("$1" "$2")
          ;;
      esac
      shift 2
      continue
      ;;
    *)
      append_input_token "$1"
      ;;
  esac
  shift
done

if [[ ! -t 0 && "${action}" != "home" && "${action}" != "help" && "${action}" != "send-later" ]]; then
  while IFS= read -r line; do
    line="${line//,/ }"
    # Intentional shell-word splitting for simple pipe-friendly wrapper input.
    # shellcheck disable=SC2206
    tokens=(${line})
    for token in "${tokens[@]}"; do
      [[ -n "${token}" ]] && append_input_token "${token}"
    done
  done
fi

for diagnostic in "${json_alias_diagnostics[@]}"; do
  echo "${diagnostic}" >&2
done

if [[ "${action}" == "sync" ]]; then
  resolved_sync_paths=()
  for sync_path in "${sync_paths[@]}"; do
    if [[ "${sync_path}" != /* ]]; then
      sync_path="${invoke_cwd}/${sync_path}"
    fi
    resolved_sync_paths+=("$(realpath_portable "${sync_path}")")
  done
  sync_paths=("${resolved_sync_paths[@]}")
fi

if [[ "${action}" == "skills" && ${#passthrough_args[@]} -gt 0 ]]; then
  case "${passthrough_args[0]}" in
    audit)
      action="skill-audit"
      passthrough_args=("${passthrough_args[@]:1}")
      ;;
    candidates|candidate|explore|inventory)
      action="skill-candidates"
      passthrough_args=("${passthrough_args[@]:1}")
      ;;
    plan|add|move|remove|prune|sync)
      action="skill"
      ;;
  esac
fi

service_flags=()
for service in "${services[@]}"; do
  service_flags+=(--service "${service}")
done

client_flags=()
if [[ -n "${client}" ]]; then
  client_flags=(--client "${client}")
fi
runtime_client_flags=()
if [[ -n "${client}" ]]; then
  runtime_client_flags=(--client "${client}")
else
  runtime_client_flags=(--cwd "${invoke_cwd}")
fi

cd "${skillbox_root}"

case "${action}" in
  home)
    echo "${wrapper_name}: ${client:-auto} ${profile}"
    echo "cwd: ${invoke_cwd}"
    python3 .env-manager/manage.py skills "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" --issues-only --limit 20 --no-global || true
    echo
    echo "next:"
    echo "  ${wrapper_name} status --json runtime status"
    echo "  ${wrapper_name} up --dry-run  preview services"
    echo "  ${wrapper_name} skills --issues-only full skill drift check"
    echo "  ${wrapper_name} candidates   source inventory for definitely/maybe/no review"
    echo "  ${wrapper_name} mcp           Claude/Codex MCP config parity"
    echo "  ${wrapper_name} mcp sync      Render .mcp.json + .codex/config.toml from declaration"
    echo "  ${wrapper_name} launch <dir> <dir> --request '<prompt>' --dry-run --json"
    echo "                         preview Swimmers batch launch (bulk alias)"
    echo "  ${wrapper_name} skills --full full skill view"
    echo "  ${wrapper_name} help          command reference"
    ;;
  help)
    print_help
    ;;
  capabilities)
    print_capabilities
    ;;
  robot-docs)
    if [[ " ${passthrough_args[*]} " == *" --format json "* ]]; then
      python3 - "${wrapper_name}" "$(print_robot_docs)" <<'PY'
from __future__ import annotations

import json
import sys

print(json.dumps({"ok": True, "topic": "guide", "guide": sys.argv[2]}, indent=2, sort_keys=True))
PY
    else
      print_robot_docs
    fi
    ;;
  robot-triage)
    print_robot_triage
    ;;
  up)
    python3 .env-manager/manage.py up "${runtime_client_flags[@]}" --profile "${profile}" --mode "${mode}" "${runtime_args[@]}" "${service_flags[@]}"
    ;;
  down)
    python3 .env-manager/manage.py down "${runtime_client_flags[@]}" --profile "${profile}" "${runtime_args[@]}" "${service_flags[@]}"
    ;;
  restart)
    python3 .env-manager/manage.py restart "${runtime_client_flags[@]}" --profile "${profile}" "${runtime_args[@]}" "${service_flags[@]}"
    ;;
  status)
    python3 .env-manager/manage.py status "${runtime_client_flags[@]}" --profile "${profile}" "${runtime_args[@]}"
    ;;
  logs)
    if [[ ${#services[@]} -eq 0 ]]; then
      echo "${wrapper_name} logs: pass at least one service. Exact command: ${wrapper_name} logs <profile> <service> --json" >&2
      echo "List services first: ${wrapper_name} status --json" >&2
      exit 2
    fi
    python3 .env-manager/manage.py logs "${runtime_client_flags[@]}" --profile "${profile}" "${runtime_args[@]}" "${service_flags[@]}"
    ;;
  swimmers-launch)
    python3 .env-manager/manage.py swimmers-launch --invoke-cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  mmdx)
    python3 .env-manager/manage.py mmdx --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  operator-booking)
    python3 .env-manager/manage.py operator-booking "${runtime_client_flags[@]}" --profile "${profile}" "${passthrough_args[@]}"
    ;;
  skills)
    python3 .env-manager/manage.py skills "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  skill-candidates)
    python3 .env-manager/manage.py skills "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" --show-sources --full --no-global "${passthrough_args[@]}"
    ;;
  skill-audit)
    python3 .env-manager/manage.py skill-audit "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  mcp-audit)
    python3 .env-manager/manage.py mcp-audit "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  mcp-sync)
    python3 .env-manager/manage.py mcp sync "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  fleet)
    # `sbp fleet converge [...]` -> read-only per-repo heal PLAN (no apply).
    # `sbp fleet relink  [...]` -> machine-migration link rewrite (dry-run by
    #                              default; --yes applies the rewrites).
    fleet_action="${passthrough_args[0]:-converge}"
    if [[ "${fleet_action}" == --* ]]; then
      fleet_action="converge"
      fleet_args=("${passthrough_args[@]}")
    elif [[ ${#passthrough_args[@]} -gt 0 ]]; then
      fleet_args=("${passthrough_args[@]:1}")
    else
      fleet_args=()
    fi
    case "${fleet_action}" in
      converge)
        python3 .env-manager/manage.py fleet converge "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${fleet_args[@]}"
        ;;
      relink)
        python3 .env-manager/manage.py fleet relink "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${fleet_args[@]}"
        ;;
      *)
        echo "${wrapper_name} fleet: unknown action '${fleet_action}' (expected converge|relink)" >&2
        exit 2
        ;;
    esac
    ;;
  structure-doctor)
    python3 .env-manager/manage.py structure-doctor --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    ;;
  cass)
    config_root="${SKILLBOX_CONFIG_ROOT:-${HOME}/repos/skillbox-config}"
    cass_wrapper="${config_root}/scripts/sbp_cass.py"
    if [[ ! -f "${cass_wrapper}" ]]; then
      echo "${wrapper_name} cass: missing Cass wrapper at ${cass_wrapper}" >&2
      exit 1
    fi
    python3 "${cass_wrapper}" "${passthrough_args[@]}"
    ;;
  cass-evidence)
    config_root="${SKILLBOX_CONFIG_ROOT:-${HOME}/repos/skillbox-config}"
    evidence_wrapper="${config_root}/scripts/sbp_evidence.py"
    if [[ ! -f "${evidence_wrapper}" ]]; then
      echo "${wrapper_name} evidence: missing evidence helper at ${evidence_wrapper}" >&2
      exit 1
    fi
    python3 "${evidence_wrapper}" "${passthrough_args[@]}"
    ;;
  cron)
    config_root="${SKILLBOX_CONFIG_ROOT:-${HOME}/repos/skillbox-config}"
    cron_wrapper="${config_root}/scripts/cron-sync.sh"
    if [[ ! -f "${cron_wrapper}" ]]; then
      echo "${wrapper_name} cron: missing cron-sync at ${cron_wrapper}" >&2
      exit 1
    fi
    bash "${cron_wrapper}" "${passthrough_args[@]}"
    ;;
  send-later)
    send_later_wrapper="${script_dir}/sbp_send_later.sh"
    if [[ ! -f "${send_later_wrapper}" ]]; then
      echo "${wrapper_name} send-later: missing helper at ${send_later_wrapper}" >&2
      exit 1
    fi
    bash "${send_later_wrapper}" "${passthrough_args[@]}"
    ;;
  repo-registry)
    config_root="${SKILLBOX_CONFIG_ROOT:-${HOME}/repos/skillbox-config}"
    registry_doctor="${config_root}/scripts/registry_doctor.py"
    registry_action="${passthrough_args[0]:-doctor}"
    if [[ "${registry_action}" == --* ]]; then
      registry_action="doctor"
      registry_args=("${passthrough_args[@]}")
    elif [[ ${#passthrough_args[@]} -gt 0 ]]; then
      registry_args=("${passthrough_args[@]:1}")
    else
      registry_args=()
    fi
    if [[ ! -f "${registry_doctor}" ]]; then
      echo "${wrapper_name} registry: missing registry doctor at ${registry_doctor}" >&2
      exit 1
    fi
    case "${registry_action}" in
      doctor|status|"")
        python3 "${registry_doctor}" "${registry_args[@]}"
        ;;
      *)
        echo "${wrapper_name} registry: unknown action '${registry_action}' (expected doctor)" >&2
        exit 2
        ;;
    esac
    ;;
  recalibrate)
    recalibrate_fleet="false"
    recalibrate_auto_fix="false"
    recalibrate_apply="false"
    recalibrate_wants_json="false"
    recalibrate_cwd="${invoke_cwd}"
    recalibrate_args=()
    index=0
    while [[ ${index} -lt ${#passthrough_args[@]} ]]; do
      token="${passthrough_args[$index]}"
      case "${token}" in
        --fleet|fleet|--all-repos)
          recalibrate_fleet="true"
          ;;
        --auto-fix)
          recalibrate_auto_fix="true"
          ;;
        --yes)
          recalibrate_apply="true"
          ;;
        --format)
          index=$((index + 1))
          if [[ ${index} -ge ${#passthrough_args[@]} ]]; then
            echo "sbp recalibrate: --format requires a value" >&2
            exit 2
          fi
          if [[ "${passthrough_args[$index]}" == "json" ]]; then
            recalibrate_wants_json="true"
          else
            recalibrate_args+=("--format" "${passthrough_args[$index]}")
          fi
          ;;
        --cwd)
          index=$((index + 1))
          if [[ ${index} -ge ${#passthrough_args[@]} ]]; then
            echo "sbp recalibrate: --cwd requires a path" >&2
            exit 2
          fi
          recalibrate_cwd="${passthrough_args[$index]}"
          ;;
        --cwd=*)
          recalibrate_cwd="${token#--cwd=}"
          ;;
        *)
          recalibrate_args+=("${token}")
          ;;
      esac
      index=$((index + 1))
    done
    if [[ "${recalibrate_wants_json}" == "true" ]]; then
      if [[ "${recalibrate_auto_fix}" == "true" ]]; then
        python3 - "${wrapper_name}" "${recalibrate_cwd}" <<'PY'
from __future__ import annotations

import json
import sys

wrapper = sys.argv[1]
cwd = sys.argv[2]
payload = {
    "ok": False,
    "error": {
        "code": "UNSUPPORTED_JSON_AUTO_FIX",
        "message": "sbp recalibrate --auto-fix cannot be combined with --json.",
        "context": {"cwd": cwd},
        "next_actions": [
            f"{wrapper} recalibrate --json",
            "Read fixes[].command from the JSON payload, then run the selected command explicitly.",
            f"{wrapper} recalibrate --auto-fix",
        ],
    },
}
print(json.dumps(payload, indent=2, sort_keys=True))
PY
        exit 2
      fi
      if [[ "${recalibrate_fleet}" == "true" ]]; then
        python3 .env-manager/manage.py skill-audit "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --format json "${recalibrate_args[@]}"
        exit $?
      fi
      recalibrate_json_argv=(
        python3 scripts/gen_output_schemas.py
        --recalibrate-json
        --cwd "${recalibrate_cwd}"
        --profile "${profile}"
      )
      if [[ -n "${client}" ]]; then
        recalibrate_json_argv+=(--client "${client}")
      fi
      if [[ ${#recalibrate_args[@]} -gt 0 ]]; then
        recalibrate_json_argv+=("${recalibrate_args[@]}")
      fi
      "${recalibrate_json_argv[@]}"
      exit $?
    fi
    if [[ "${recalibrate_fleet}" == "true" ]]; then
      if [[ "${recalibrate_auto_fix}" == "true" ]]; then
        echo "sbp recalibrate: --auto-fix is cwd-only; omit --fleet or use fleet converge dry-runs" >&2
        exit 2
      fi
      python3 .env-manager/manage.py skill-audit "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" "${recalibrate_args[@]}"
      echo
      echo "review dry-runs before applying:"
      echo "  sbp skill sync --cwd <repo> --dry-run"
      echo "  sbp skill prune --cwd <repo> --from project --dry-run"
      echo "  sbp skill remove <skill> --cwd <repo> --from project --dry-run"
      echo "  sbp skill prune --from global --dry-run"
      echo "  sbp overlay activate marketing --cwd <repo>"
    else
      echo "sbp recalibrate: ${client:-auto} ${profile}"
      echo "cwd: ${recalibrate_cwd}"
      echo
      echo "policy issues for this repo:"
      python3 .env-manager/manage.py skills "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --issues-only --no-global "${recalibrate_args[@]}" || true
      echo
      echo "repo skill override lint:"
      python3 .env-manager/manage.py skill lint "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" || true
      echo
      echo "add missing repo-local skills:"
      python3 .env-manager/manage.py skill sync "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --dry-run || true
      echo
      echo "remove repo-local policy violations:"
      python3 .env-manager/manage.py skill prune "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --from project --dry-run || true
      if [[ "${recalibrate_auto_fix}" == "true" ]]; then
        auto_fix_failed=0
        echo
        echo "auto-fix missing repo-local skills:"
        if [[ "${recalibrate_apply}" == "true" ]]; then
          echo "mode: apply (--yes)"
        else
          echo "mode: dry-run (pass --yes to apply)"
        fi
        missing_json="$(mktemp)"
        missing_names="$(mktemp)"
        if ! python3 .env-manager/manage.py skills "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --issues-only --no-global --format json > "${missing_json}"; then
          printf '{}\n' > "${missing_json}"
          auto_fix_failed=1
        fi
        python3 - "${missing_json}" > "${missing_names}" <<'PY'
from __future__ import annotations

import json
import sys

try:
    payload = json.load(open(sys.argv[1], encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    payload = {}
names: list[str] = []
seen: set[str] = set()
for item in ((payload.get("issues") or {}).get("missing_for_cwd") or []):
    name = str(item.get("name") or item.get("skill") or "").strip()
    if not name or name in seen:
        continue
    seen.add(name)
    names.append(name)
for name in names:
    print(name)
PY
        if [[ ! -s "${missing_names}" ]]; then
          echo "  none"
        else
          while IFS= read -r missing_skill; do
            [[ -z "${missing_skill}" ]] && continue
            if [[ "${recalibrate_apply}" == "true" ]]; then
              if ! python3 .env-manager/manage.py skill heal "${missing_skill}" "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --format json; then
                auto_fix_failed=1
              fi
            else
              if ! python3 .env-manager/manage.py skill heal "${missing_skill}" "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --dry-run --format json; then
                auto_fix_failed=1
              fi
            fi
          done < "${missing_names}"
        fi
        rm -f "${missing_json}" "${missing_names}"
      fi
      echo
      echo "beads graph:"
      python3 .env-manager/manage.py skills "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" --issues-only --format json \
        | python3 -c '
import json, sys
payload = json.load(sys.stdin)
beads = payload.get("beads") or {}
if not beads.get("required"):
    print("beads: not required by currently effective skills")
else:
    skills = ", ".join(item.get("name", "") for item in beads.get("required_skills", [])) or "(none)"
    repo = beads.get("repo_root") or "(no git repo)"
    initialized = "yes" if beads.get("initialized") else "no"
    br_ready = "yes" if beads.get("br") else "no"
    print(f"beads: required by {skills}; repo={repo}; initialized={initialized}; br={br_ready}")
    for issue in beads.get("issues") or []:
        message = issue.get("message")
        print(f"  - {message}")
        hint = issue.get("hint")
        if hint:
            print(f"    next: {hint}")
' || true
      echo
      echo "mcp config parity:"
      python3 .env-manager/manage.py mcp-audit "${client_flags[@]}" --profile "${profile}" --cwd "${recalibrate_cwd}" || true
      echo
      echo "broader checks:"
      echo "  sbp mcp"
      echo "  sbp candidates --json"
      echo "  sbp recalibrate --fleet --limit 20"
      echo "  sbp skill prune --from global --dry-run"
      echo "  sbp overlay activate marketing --cwd \"${recalibrate_cwd}\""
      if [[ "${recalibrate_auto_fix:-false}" == "true" && "${auto_fix_failed:-0}" -ne 0 ]]; then
        echo "sbp recalibrate --auto-fix: one or more heal commands failed" >&2
        exit 1
      fi
    fi
    ;;
  beads)
    beads_action="${passthrough_args[0]:-status}"
    if [[ ${#passthrough_args[@]} -gt 0 ]]; then
      beads_args=("${passthrough_args[@]:1}")
    else
      beads_args=()
    fi
    beads_cwd="${invoke_cwd}"
    normalized_beads_args=()
    index=0
    while [[ ${index} -lt ${#beads_args[@]} ]]; do
      token="${beads_args[$index]}"
      case "${token}" in
        --cwd)
          index=$((index + 1))
          if [[ ${index} -ge ${#beads_args[@]} ]]; then
            echo "sbp beads: --cwd requires a path" >&2
            exit 2
          fi
          beads_cwd="${beads_args[$index]}"
          ;;
        --cwd=*)
          beads_cwd="${token#--cwd=}"
          ;;
        *)
          normalized_beads_args+=("${token}")
          ;;
      esac
      index=$((index + 1))
    done
    if ! command -v br >/dev/null 2>&1; then
      echo "sbp beads: br is not on PATH" >&2
      exit 1
    fi
    beads_has_git="false"
    if repo_root="$(git -C "${beads_cwd}" rev-parse --show-toplevel 2>/dev/null)"; then
      beads_has_git="true"
      repo_root="$(realpath_portable "${repo_root}")"
    else
      repo_root="$(realpath_portable "${beads_cwd}")"
    fi
    case "${beads_action}" in
      status|"")
        echo "sbp beads status"
        echo "cwd: ${beads_cwd}"
        echo "repo: ${repo_root}"
        if [[ "${beads_has_git}" != "true" ]]; then
          echo "BEADS DRIFT: cwd is not inside a git repo"
          echo "next: run from the target repo root or a repo subdirectory"
        elif [[ ! -d "${repo_root}/.beads" ]]; then
          echo "BEADS DRIFT: .beads/ is not initialized for this repo"
          echo "next: sbp beads init --cwd \"${repo_root}\""
        else
          (cd "${repo_root}" && br where && br status "${normalized_beads_args[@]}")
        fi
        ;;
      init)
        if [[ "${beads_has_git}" != "true" || ! -e "${repo_root}/.git" ]]; then
          echo "sbp beads init: ${beads_cwd} is not inside a git repo; refusing to create .beads outside a repo root" >&2
          exit 1
        fi
        (
          cd "${repo_root}"
          if [[ ! -d ".beads" ]]; then
            br init
          fi
          br agents --add --force
          br doctor --json
        )
        ;;
      sync)
        if [[ ! -d "${repo_root}/.beads" ]]; then
          echo "sbp beads sync: .beads/ is not initialized; run sbp beads init --cwd \"${repo_root}\"" >&2
          exit 1
        fi
        (cd "${repo_root}" && br sync --flush-only "${normalized_beads_args[@]}")
        ;;
      *)
        echo "sbp beads: unknown action '${beads_action}' (expected status, init, or sync)" >&2
        exit 2
        ;;
    esac
    ;;
  skill)
    if [[ ${#passthrough_args[@]} -eq 0 ]]; then
      echo "sbp skill: pass an action, e.g. 'sbp skill on wiki --verify' or 'sbp skill add ui --to project'" >&2
      exit 2
    fi
    skill_action="${passthrough_args[0]}"
    skill_args=("${passthrough_args[@]:1}")
    python3 .env-manager/manage.py skill "${skill_action}" "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${skill_args[@]}"
    ;;
  overlay)
    python3 .env-manager/manage.py overlay "${client_flags[@]}" --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    if overlay_should_sync_policy; then
      echo
      echo "applying policy for this cwd..."
      overlay_sync_args=()
      if passthrough_has_arg "--dry-run"; then
        overlay_sync_args+=(--dry-run)
      fi
      python3 .env-manager/manage.py skill sync "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${overlay_sync_args[@]}" || true
    fi
    ;;
  overlay-toggle)
    python3 .env-manager/manage.py overlay toggle "${overlay_name}" "${client_flags[@]}" --cwd "${invoke_cwd}" "${passthrough_args[@]}"
    echo
    echo "applying policy for this cwd..."
    overlay_sync_args=()
    if passthrough_has_arg "--dry-run"; then
      overlay_sync_args+=(--dry-run)
    fi
    python3 .env-manager/manage.py skill sync "${client_flags[@]}" --profile "${profile}" --cwd "${invoke_cwd}" "${overlay_sync_args[@]}" || true
    ;;
  sync)
    if [[ ${#sync_paths[@]} -eq 0 ]]; then
      echo "sbp sync: pass at least one skill path, e.g. 'sbp sync /path/to/ga4'" >&2
      exit 2
    fi
    if [[ "${sync_dry_run}" != "true" && "${sync_yes}" != "true" ]]; then
      echo "sbp sync: legacy global sync requires --dry-run to preview or --yes to apply" >&2
      echo "Prefer durable repo-local activation: ${wrapper_name} skill on <skill> --cwd \"${invoke_cwd}\" --dry-run" >&2
      exit 2
    fi
    legacy_sync_args=()
    if [[ "${sync_dry_run}" == "true" ]]; then
      legacy_sync_args+=(--dry-run)
    fi
    for sync_path in "${sync_paths[@]}"; do
      if [[ ! -d "${sync_path}" ]]; then
        echo "sbp sync: not a directory: ${sync_path}" >&2
        exit 1
      fi
      if [[ ! -f "${sync_path}/SKILL.md" ]]; then
        echo "sbp sync: missing SKILL.md in ${sync_path}" >&2
        exit 1
      fi
      skill_name="$(basename "${sync_path}")"
      python3 .env-manager/manage.py skill add "${skill_name}" \
        "${client_flags[@]}" \
        --profile "${profile}" \
        --cwd "${invoke_cwd}" \
        --to global \
        --source "${sync_path}" \
        "${legacy_sync_args[@]}"
    done
    ;;
esac
