#!/usr/bin/env bash

set -eo pipefail
# macOS still ships Bash 3.2, where nounset treats empty arrays as unbound.
# This wrapper intentionally builds many optional argv arrays, so keep nounset
# only on Bash releases with the fixed empty-array behavior.
if (( BASH_VERSINFO[0] > 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 4) )); then
  set -u
fi

client="${SKILLBOX_CLIENT:-}"
profile="${SKILLBOX_PROFILE:-local-all}"
mode="${SKILLBOX_MODE:-reuse}"
action="home"
services=()
sync_paths=()
sync_dry_run="false"
sync_yes="false"
passthrough_args=()
runtime_args=()
json_alias_diagnostics=()
invoke_cwd=""
overlay_name=""

realpath_portable() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1"
}

script_source="${BASH_SOURCE[0]:-${0:-}}"
script_path="$(realpath_portable "${script_source}")"
script_dir="$(cd "$(dirname "${script_path}")" && pwd -P)"
wrapper_name="${SKILLBOX_WRAPPER_NAME:-$(basename "${script_path}")}"
invoke_cwd="${SKILLBOX_INVOKE_CWD:-$(pwd -P)}"

find_skillbox_root() {
  local candidate=""
  local candidates=()
  if [[ -n "${SKILLBOX_ROOT:-}" ]]; then
    candidates+=("${SKILLBOX_ROOT}")
  fi
  if [[ -n "${SKILLBOX_OPERATOR_REPOS_ROOT:-}" ]]; then
    candidates+=("${SKILLBOX_OPERATOR_REPOS_ROOT}/opensource/skillbox")
  fi
  if [[ -z "${SKILLBOX_ROOT:-}" ]]; then
    candidates+=("${script_dir}/..")
    candidates+=("/srv/skillbox/repos/opensource/skillbox")
  fi
  candidates+=(
    "${HOME}/repos/opensource/skillbox"
    "${HOME}/skillbox"
  )
  for candidate in "${candidates[@]}"; do
    if [[ -f "${candidate}/.env-manager/manage.py" ]]; then
      realpath_portable "${candidate}"
      return 0
    fi
  done
  return 1
}

configure_operator_defaults() {
  local config_candidate=""
  local config_root=""
  local config_candidates=()
  local inferred_operator_repos_root=""
  local repos_candidate=""
  local repos_root=""
  local repos_candidates=()
  if [[ -n "${SKILLBOX_ROOT:-}" ]]; then
    inferred_operator_repos_root="$(realpath_portable "${SKILLBOX_ROOT}/../..")"
  fi
  if [[ -n "${SKILLBOX_CONFIG_ROOT:-}" ]]; then
    config_candidates+=("${SKILLBOX_CONFIG_ROOT}")
  fi
  if [[ -n "${SKILLBOX_OPERATOR_REPOS_ROOT:-}" ]]; then
    config_candidates+=("${SKILLBOX_OPERATOR_REPOS_ROOT}/skillbox-config")
  fi
  if [[ -n "${inferred_operator_repos_root}" && -d "${inferred_operator_repos_root}/skillbox-config/clients" ]]; then
    config_candidates+=("${inferred_operator_repos_root}/skillbox-config")
  fi
  if [[ -z "${SKILLBOX_ROOT:-}" ]]; then
    config_candidates+=("/srv/skillbox/repos/skillbox-config")
  fi
  config_candidates+=("${HOME}/repos/skillbox-config")

  for config_candidate in "${config_candidates[@]}"; do
    if [[ -d "${config_candidate}/clients" ]]; then
      config_root="$(realpath_portable "${config_candidate}")"
      break
    fi
  done

  if [[ -n "${config_root}" && -z "${SKILLBOX_CONFIG_ROOT:-}" ]]; then
    export SKILLBOX_CONFIG_ROOT="${config_root}"
  fi
  if [[ -n "${config_root}" && -z "${SKILLBOX_CLIENTS_HOST_ROOT:-}" ]]; then
    export SKILLBOX_CLIENTS_HOST_ROOT="${config_root}/clients"
  fi
  if [[ -n "${SKILLBOX_MONOSERVER_ROOT:-}" ]]; then
    repos_candidates+=("${SKILLBOX_MONOSERVER_ROOT}")
  fi
  if [[ -n "${SKILLBOX_MONOSERVER_HOST_ROOT:-}" ]]; then
    repos_candidates+=("${SKILLBOX_MONOSERVER_HOST_ROOT}")
  fi
  if [[ -n "${SKILLBOX_OPERATOR_REPOS_ROOT:-}" ]]; then
    repos_candidates+=("${SKILLBOX_OPERATOR_REPOS_ROOT}")
  fi
  if [[ -n "${inferred_operator_repos_root}" && -d "${inferred_operator_repos_root}/skillbox-config/clients" ]]; then
    repos_candidates+=("${inferred_operator_repos_root}")
  fi
  if [[ -z "${SKILLBOX_ROOT:-}" ]]; then
    repos_candidates+=("/srv/skillbox/repos")
  fi
  repos_candidates+=("${HOME}/repos")

  for repos_candidate in "${repos_candidates[@]}"; do
    if [[ -d "${repos_candidate}" ]]; then
      if [[ "${repos_candidate}" == "${HOME}/repos" ]]; then
        repos_root="${repos_candidate}"
      else
        repos_root="$(realpath_portable "${repos_candidate}")"
      fi
      break
    fi
  done

  if [[ -n "${repos_root}" && -z "${SKILLBOX_MONOSERVER_ROOT:-}" ]]; then
    export SKILLBOX_MONOSERVER_ROOT="${repos_root}"
  fi
  if [[ -n "${repos_root}" && -z "${SKILLBOX_MONOSERVER_HOST_ROOT:-}" ]]; then
    export SKILLBOX_MONOSERVER_HOST_ROOT="${repos_root}"
  fi
}

print_help() {
  cat <<'EOF' | sed "s/__WRAPPER__/${wrapper_name}/g"
__WRAPPER__ - personal skillbox runtime and skill helper

Usage:
  __WRAPPER__                         Compact home view for this cwd
  __WRAPPER__ help                    Show this help
  __WRAPPER__ capabilities --json     Print the wrapper machine contract
  __WRAPPER__ robot-docs guide        Print agent-facing command guidance
  __WRAPPER__ robot-triage            Print compact first actions
  __WRAPPER__ up [profile] [service]  Start services (default profile: local-all)
  __WRAPPER__ down [profile] [svc]    Stop services
  __WRAPPER__ restart [profile] [svc] Restart services
  __WRAPPER__ status [profile]        Runtime status
  __WRAPPER__ logs [profile] service  Show service logs
  __WRAPPER__ launch DIR... --request "..."  Launch one Swimmers agent per dir
  __WRAPPER__ bulk DIR... --request "..."    Alias for launch
  __WRAPPER__ recalibrate [args...]   Read cwd skill drift; --auto-fix previews heal, --yes applies
  __WRAPPER__ candidates [args...]    Explore linkable skill sources for this cwd
  __WRAPPER__ mcp [args...]           Read-only Claude JSON / Codex TOML MCP audit
  __WRAPPER__ mcp sync [args...]     Render .mcp.json + .codex/config.toml from declaration (--dry-run default)
  __WRAPPER__ doctor [--format json]  One front door for all STRUCTURAL gates
                              (INCO/FAIL/PASS); complements `make doctor`.
                              Exits nonzero on FAIL only.
  __WRAPPER__ registry doctor [args...] Check registry/repos.yaml against local Git repos
  __WRAPPER__ cass status|search|rebuild|doctor  Remote Cass front door.
                              Use status/search for active tasks; treat rebuild as
                              coordinated maintenance, not degraded-mode fallback.
  __WRAPPER__ evidence [--repo P|--skill N] --format json  Measure skill invocations per
                              repo from Cass (contamination-safe), joined to current policy
  __WRAPPER__ cron [status|apply]     Declared crontab + script links from skillbox-config
  __WRAPPER__ send-later [list|doctor|new|panes] Schedule/inspect delayed/recurring tmux/NTM sends (--json on list/doctor/panes)
  __WRAPPER__ beads [status|init|sync] Check or initialize repo-local beads state
  __WRAPPER__ mmdx QUERY              Fuzzy-find and open .mmdx/.mmd from this cwd
  __WRAPPER__ mmdx                    List recent .mmdx/.mmd files from this repo
  __WRAPPER__ hire times              Show configured human-operator availability
  __WRAPPER__ hire book [args...]     Send magic-link/signup email and create x402 hold
                              Set SPAPS_AUTH_ACCESS_TOKEN to bind to a verified account.

Skills:
  __WRAPPER__ skills [args...]        Show effective skills for this cwd
  __WRAPPER__ skills --issues-only    Compact skill drift/policy view
  __WRAPPER__ skills audit            Scan downstream repos for skill policy drift
  __WRAPPER__ skill plan NAME         Preview where NAME would be linked
  __WRAPPER__ skill add NAME          Link NAME into global/project/category roots
  __WRAPPER__ skill why NAME          Explain visibility layers and exact fixes
  __WRAPPER__ skill togglable         List cwd-flippable skills and exact flip commands
  __WRAPPER__ skill what-if --repo R  Simulate overlay/pin visibility with zero writes
  __WRAPPER__ skill on NAME           Durably pin NAME on for this repo
  __WRAPPER__ skill off NAME          Durably pin NAME off for this repo
  __WRAPPER__ skill default on NAME --repo --dry-run
                                      Preview repo/global default policy edits
  __WRAPPER__ skill heal NAME         Resolve source, pin on, link, and print activation packet
  __WRAPPER__ skill sync --dry-run    Link cwd-required missing skills
  __WRAPPER__ skill prune --dry-run   Preview policy-violation unlinks
  __WRAPPER__ sync /path/to/skill     Legacy shorthand for global skill add

Overlays:
  __WRAPPER__ m                       Toggle the marketing overlay on/off.
                              Off-flip unlinks overlay-scoped symlinks.
                              Pass --keep to preserve them.
  __WRAPPER__ overlay                 List active overlays
  __WRAPPER__ overlay on NAME         Enable overlay (e.g. marketing)
  __WRAPPER__ overlay off NAME        Disable overlay + unlink overlay-scoped symlinks
  __WRAPPER__ overlay off NAME --keep Disable overlay, keep symlinks in place
  __WRAPPER__ overlay toggle NAME     Flip overlay state (off-flip unlinks unless --keep)

Profiles:
  all | local-all, core | local-core, minimal | mini | local-minimal,
  backend | local-backend, frontend | front | local-frontend,
  openclaw | claw | local-openclaw

Examples:
  __WRAPPER__
  __WRAPPER__ status core --json
  __WRAPPER__ down core api --dry-run --json
  __WRAPPER__ skills --issues-only
  __WRAPPER__ candidates --json
  __WRAPPER__ recalibrate
  __WRAPPER__ recalibrate --auto-fix
  __WRAPPER__ mcp
  __WRAPPER__ beads status
  __WRAPPER__ beads init
  __WRAPPER__ recalibrate --fleet --limit 20
  __WRAPPER__ skill plan mcp-server-design
  __WRAPPER__ skill add ui --to category --category frontend
  __WRAPPER__ skill why wiki --json
  __WRAPPER__ skill togglable --json
  __WRAPPER__ skill what-if --repo . --overlay marketing --json
  __WRAPPER__ skill on wiki --verify
  __WRAPPER__ skill off wiki --dry-run
  __WRAPPER__ skill default on wiki --repo --dry-run
  __WRAPPER__ skill lint             Lint .skillbox/skill-overrides.yaml
  __WRAPPER__ mmdx review
  __WRAPPER__ mmdx skill review --no-open
  __WRAPPER__ launch ../api ../web --request 'Audit auth drift' --dry-run --json
  __WRAPPER__ hire times --limit 3
  __WRAPPER__ hire book --date 2026-05-06 --slot AM --email person@example.com --name "Person" --send-magic-link
  __WRAPPER__ up backend spaps
EOF
}

