## chart erd Runtime Skillset Drift ERD
```mermaid
erDiagram
  RUNTIME_SKILLSET ||--|| SKILL_REPOS_CONFIG : uses
  SKILL_REPOS_CONFIG ||--o{ DECLARED_SKILL : declares
  SKILL_REPOS_CONFIG ||--|| STALE_LOCKFILE : should_hash_to
  STALE_LOCKFILE ||--o{ LOCKED_EXTRA_SKILL : still_records
  RUNTIME_SKILLSET ||--o{ INSTALL_TARGET : installs_into
  INSTALL_TARGET ||--o{ INSTALLED_EXTRA_SKILL : contains
  RUNTIME_SKILLSET ||--o{ OPTIONAL_ARTIFACT : checks
  LEGEND ||--o{ INSTALLED_EXTRA_SKILL : red_means_drift

  RUNTIME_SKILLSET {
    string id "UNCHANGED default-skills"
    string profile "UNCHANGED core"
    string kind "UNCHANGED skill-repo-set"
  }
  SKILL_REPOS_CONFIG {
    string path "UNCHANGED workspace/skill-repos.yaml"
    string declared_count "UNCHANGED 17 skills"
  }
  DECLARED_SKILL {
    string examples "UNCHANGED ask-cascade, commit, skillbox-operator"
  }
  STALE_LOCKFILE {
    string path "CHANGED workspace/skill-repos.lock.json"
    string failure "BLOCKER config_sha mismatch"
  }
  LOCKED_EXTRA_SKILL {
    string extras "REMOVED changelog-md, readme-writing, smart"
  }
  INSTALL_TARGET {
    string claude "UNCHANGED home/.claude/skills"
    string codex "UNCHANGED home/.codex/skills"
  }
  INSTALLED_EXTRA_SKILL {
    string extras "REMOVED cass, cass-memory, changelog-md, ga4, readme-writing, smart"
  }
  OPTIONAL_ARTIFACT {
    string dcg "LOW missing optional binary"
    string swimmers "LOW missing optional binary"
  }
  LEGEND {
    string green "ADDED"
    string amber "CHANGED"
    string red "REMOVED or drift"
    string grey "UNCHANGED"
  }
```
