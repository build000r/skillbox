{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v dcg >/dev/null 2>&1 && dcg || true"
          }
        ]
      },
      {
        "matcher": "mcp__skillbox-operator__operator_teardown",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/guard-destructive-op.sh"
          }
        ]
      },
      {
        "matcher": "mcp__skillbox-operator__operator_compose_down",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/guard-destructive-op.sh"
          }
        ]
      }
    ]
  }
}
